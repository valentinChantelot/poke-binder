#!/usr/bin/env bash
set -euo pipefail

MSG=$(grep -v '^#' "$1" | head -1)

# Pass through automated commits: merges, reverts, fixup/squash
if [[ "$MSG" =~ ^(Merge|Revert|fixup!|squash!) ]]; then
  exit 0
fi

[[ -z "$MSG" ]] && exit 0

if [[ ! -x node_modules/.bin/commitlint ]]; then
  echo "commit-msg: commitlint not found — run 'pnpm install' first" >&2
  exit 1
fi

pnpm exec commitlint --edit "$1"
