#!/usr/bin/env bash
set -euo pipefail

branch=$(git branch --show-current)
if [[ "$branch" == "main" ]] && [[ ! -f .git/MERGE_HEAD ]]; then
  echo "pre-commit: direct commits to 'main' are not allowed." >&2
  echo "          Create a branch first: git checkout -b feat/my-feature" >&2
  exit 1
fi

if [[ ! -x node_modules/.bin/lint-staged ]]; then
  echo "pre-commit: lint-staged not found — run 'pnpm install' first" >&2
  exit 1
fi

pnpm exec lint-staged
